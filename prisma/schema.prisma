generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum BookingStatus {
    PENDING   @map("pending")
    CONFIRMED @map("confirmed")
    COMPLETED @map("completed")
    CANCELLED @map("cancelled")
}

model Doctor {
    id             String   @id @default(uuid()) @map("id") @db.Uuid
    name           String   @map("name")
    email          String   @unique @map("email")
    specialty      String?  @map("specialty")
    qualifications String?  @map("qualifications")
    bio            String?  @map("bio")
    createdAt      DateTime @default(now()) @map("created_at")

    bookings     Booking[]
    services     Service[]
    availability Availability[]

    @@map("doctors")
}

model Service {
    id              String   @id @default(uuid()) @map("id") @db.Uuid
    name            String   @map("name")
    description     String?  @map("description")
    price           Int      @map("price")
    durationMinutes Int      @map("duration_minutes")
    isActive        Boolean  @default(true) @map("is_active")
    createdAt       DateTime @default(now()) @map("created_at")

    bookings Booking[]
    doctor   Doctor?   @relation(fields: [doctorId], references: [id])
    doctorId String?   @db.Uuid

    @@map("services")
}

model Availability {
    id        String   @id @default(uuid()) @map("id") @db.Uuid
    doctorId  String   @map("doctor_id") @db.Uuid
    dayOfWeek Int      @map("day_of_week")
    startTime String   @map("start_time")
    endTime   String   @map("end_time")
    isActive  Boolean  @default(true) @map("is_active")
    createdAt DateTime @default(now()) @map("created_at")

    doctor Doctor @relation(fields: [doctorId], references: [id])

    @@map("availability")
}

model Booking {
    id                  String        @id @default(uuid()) @map("id") @db.Uuid
    bookingReference    String        @unique @map("booking_reference")
    doctorId            String        @map("doctor_id") @db.Uuid
    serviceId           String        @map("service_id") @db.Uuid
    patientName         String        @map("patient_name")
    patientEmail        String        @map("patient_email")
    patientPhone        String        @map("patient_phone")
    patientAddress      String?       @map("patient_address")
    patientCity         String?       @map("patient_city")
    patientState        String?       @map("patient_state")
    patientPincode      String?       @map("patient_pincode")
    mainConcern         String        @map("main_concern")
    comments            String?       @map("comments")
    appointmentDatetime DateTime      @map("appointment_datetime")
    timezone            String        @default("Asia/Kolkata") @map("timezone")
    status              BookingStatus @default(PENDING) @map("status")
    createdAt           DateTime      @default(now()) @map("created_at")
    updatedAt           DateTime      @default(now()) @map("updated_at")

    doctor  Doctor  @relation(fields: [doctorId], references: [id])
    service Service @relation(fields: [serviceId], references: [id])

    @@map("bookings")
}
